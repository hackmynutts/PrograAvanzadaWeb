@model ARPATicket.UI.Models.TicketEditDTO
@using ARPATicket.UI.Models
@using ARPATicket.API.Models

@{
    ViewData["Title"] = "Editar Ticket";
    var userDict = ViewBag.Users as Dictionary<int, UserDTO>;

    UserDTO? currentUser = null;
    if (Model.assignedUserID.HasValue && userDict != null)
        userDict.TryGetValue(Model.assignedUserID.Value, out currentUser);

    string pokemonSrc = (currentUser != null && currentUser.AvatarID > 0)
        ? $"https://raw.githubusercontent.com/PokeAPI/sprites/master/sprites/pokemon/{currentUser.AvatarID}.png"
        : "";
}

<style>
    .form-card {
        max-width: 520px;
        margin: 2rem auto;
        background: #fff;
        border-radius: 14px;
        box-shadow: 0 2px 12px rgba(0,0,0,0.10);
        padding: 2rem 2.5rem;
    }

    .form-card h2 {
        font-size: 1.3rem;
        font-weight: 700;
        margin-bottom: 1.5rem;
        text-align: center;
        color: #111;
    }

    .form-label {
        font-weight: 600;
        font-size: 0.88rem;
        color: #444;
    }

    .form-control, .form-select {
        border-radius: 8px;
        border: 1px solid #d1d5db;
        font-size: 0.92rem;
        padding: 0.5rem 0.75rem;
    }

    .form-control:focus, .form-select:focus {
        border-color: #2563eb;
        box-shadow: 0 0 0 3px rgba(37,99,235,0.15);
    }

    .btn-guardar {
        width: 100%;
        background: #16a34a;
        color: #fff;
        border: none;
        border-radius: 8px;
        padding: 0.6rem;
        font-weight: 600;
        font-size: 0.95rem;
        margin-top: 0.5rem;
        cursor: pointer;
        transition: background 0.15s;
    }

    .btn-guardar:hover { background: #15803d; }

    .link-back {
        display: block;
        text-align: center;
        margin-top: 1rem;
        font-size: 0.85rem;
        color: #6b7280;
        text-decoration: none;
    }

    .link-back:hover { color: #111; }

    #avatar-preview {
        align-items: center;
        gap: 0.5rem;
        margin-top: 0.5rem;
        font-size: 0.85rem;
        color: #555;
    }

    #avatar-preview img {
        width: 36px;
        height: 36px;
        object-fit: contain;
        image-rendering: pixelated;
    }
</style>

<div class="form-card">
    <h2>Editar Ticket #@Model.ticketID</h2>

    <form asp-action="Edit" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="ticketID" />

        <div class="mb-3">
            <label class="form-label">Título</label>
            <input asp-for="title" class="form-control" />
            <span asp-validation-for="title" class="text-danger small"></span>
        </div>

        <div class="mb-3">
            <label class="form-label">Descripción</label>
            <textarea asp-for="description" class="form-control" rows="3"></textarea>
            <span asp-validation-for="description" class="text-danger small"></span>
        </div>

        <div class="mb-3">
            <label class="form-label">Estado</label>
            <select asp-for="status" class="form-select">
                <option value="Open">Abierto</option>
                <option value="InProgress">En Proceso</option>
                <option value="Closed">Cerrado</option>
            </select>
        </div>

        <div class="mb-3">
            <label class="form-label">Asignar usuario</label>
            <select asp-for="assignedUserID" class="form-select" id="userSelect">
                <option value="">-- Sin asignar --</option>
                @if (userDict != null)
                {
                    foreach (var kv in userDict)
                    {
                        <option value="@kv.Key"
                                data-avatar="@kv.Value.AvatarID"
                                data-name="@kv.Value.name">
                            @kv.Value.name
                        </option>
                    }
                }
            </select>

            <div id="avatar-preview" style="display:@(pokemonSrc != "" ? "flex" : "none")">
                <img id="avatar-img" src="@pokemonSrc" alt="pokemon" />
                <span id="avatar-name">@(currentUser?.name ?? "")</span>
            </div>
        </div>

        <button type="submit" class="btn-guardar">Guardar cambios</button>
    </form>

    <a asp-action="Index" class="link-back">← Volver al Board</a>
</div>

@section Scripts {
    <script>
        const select = document.getElementById('userSelect');
        const preview = document.getElementById('avatar-preview');
        const avatarImg = document.getElementById('avatar-img');
        const avatarName = document.getElementById('avatar-name');

        select.addEventListener('change', function () {
            const opt = this.options[this.selectedIndex];
            const avatarId = opt.getAttribute('data-avatar');
            const name = opt.getAttribute('data-name');

            if (avatarId && parseInt(avatarId) > 0) {
                avatarImg.src = `https://raw.githubusercontent.com/PokeAPI/sprites/master/sprites/pokemon/${avatarId}.png`;
                avatarName.textContent = name;
                preview.style.display = 'flex';
            } else {
                preview.style.display = 'none';
            }
        });
    </script>
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
