@model List<ProjectAgile.UI.Models.StoryViewModel>

@{
    // Agrupamos las historias por su estado para mostrarlas en columnas separadas
    var backlog = Model.Where(s => s.Status == "Backlog").ToList(); // Filtramos las historias que están en el estado "Backlog" y las convertimos en una lista
    var todo = Model.Where(s => s.Status == "ToDo").ToList();
    var inprogress = Model.Where(s => s.Status == "InProgress").ToList();
    var done = Model.Where(s => s.Status == "Done").ToList();
}

<h2>Agile Board</h2>

<div class="row justify-content-center mb-4">
    <div class="col-12 col-md-10 col-lg-8 text-center">
        <h1 class="display-5 mb-3">Nueva Historia</h1>

        <form method="post" action="/Story/Create" class="row g-2 justify-content-center align-items-center">
            <div class="col-auto" style="min-width:180px;">
                <input name="title" placeholder="title" class="form-control" />
            </div>
            <div class="col-auto" style="min-width:180px;">
                <input name="description" placeholder="description" class="form-control" />
            </div>
            <div class="col-auto" style="min-width:180px;">
                <input name="assignedTo" placeholder="assignedTo" class="form-control" />
            </div>
            <div class="col-auto">
                <button type="submit" class="btn btn-primary">Crear</button>
            </div>
        </form>
    </div>
</div>

<div class="row">

    @foreach (var column in new[]
        {// Creamos un array de objetos anónimos para representar cada columna del tablero
        new { Title = "Backlog", Items = backlog }, // Cada objeto tiene un título y una lista de historias que pertenecen a esa columna
        new { Title = "To Do", Items = todo },
        new { Title = "In Progress", Items = inprogress },
        new { Title = "Done", Items = done }
        })
    {
        <div class="col-md-3">
            <h4>@column.Title</h4>

            @foreach (var story in column.Items)
            {
                <div class="card mb-3">
                    <div class="card-body">
                        <h5>@story.Title</h5>
                        <p>@story.Description</p>
                        <small>Asignado: @story.AssignedTo</small><br />
                        <small>Estimación: @story.Estimacion</small><br />
                        @if (story.Status == "Done")
                        {
                            <small>Estado: @story.Status</small>
                        }

                        @if (story.Status != "Done")
                        {
                            <form asp-controller="Story" asp-action="Update" method="post">
                                <input type="hidden" name="id" value="@story.ID" />

                                <select name="newStatus" class="form-select mt-2">
                                    <option value="Backlog" selected="@(story.Status == "Backlog")">Backlog</option>
                                    <option value="ToDo" selected="@(story.Status == "ToDo")">To Do</option>
                                    <option value="InProgress" selected="@(story.Status == "InProgress")">In Progress</option>
                                    <option value="Done" selected="@(story.Status == "Done")">Done</option>
                                </select>

                                <button type="submit" class="btn btn-primary btn-sm mt-2">
                                    Mover
                                </button>
                            </form>
                        }
                    </div>
                </div>
            }
        </div>
    }

</div>