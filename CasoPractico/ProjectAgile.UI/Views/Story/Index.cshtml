@model List<ProjectAgile.UI.Models.StoryViewModel>
@{
    // Agrupamos las historias por su estado para mostrarlas en columnas separadas
    var backlog = Model.Where(s => s.Status == "Backlog").ToList(); // Filtramos las historias que están en el estado "Backlog" y las convertimos en una lista
    var todo = Model.Where(s => s.Status == "ToDo").ToList();
    var inprogress = Model.Where(s => s.Status == "InProgress").ToList();
    var done = Model.Where(s => s.Status == "Done").ToList();
}

<h2>Agile Board</h2>

<div class="row justify-content-center mb-4">
    <div class="col-12 col-md-10 col-lg-8 text-center">
        <h1 class="display-5 mb-3">Nueva Historia</h1>

        <form method="post" action="/Story/Create" class="row g-2 justify-content-center align-items-center">
            <div class="col-auto" style="min-width:180px;">
                <input name="title" placeholder="title" class="form-control" />
            </div>
            <div class="col-auto" style="min-width:180px;">
                <input name="description" placeholder="description" class="form-control" />
            </div>
            <div class="col-auto" style="min-width:180px;">
                <input name="assignedTo" placeholder="assignedTo" class="form-control" />
            </div>
            <div class="col-auto">
                <button type="submit" class="btn btn-primary">Crear</button>
            </div>
        </form>
    </div>
</div>

@{

    var columns = new List<BoardColumnViewModel>
    {
        new BoardColumnViewModel
        {
            Title = "Backlog",
            Status = "Backlog",
            Stories = backlog
        },
        new BoardColumnViewModel
        {
            Title = "To Do",
            Status = "ToDo",
            Stories = todo
        },
        new BoardColumnViewModel
        {
            Title = "In Progress",
            Status = "InProgress",
            Stories = inprogress
        },
        new BoardColumnViewModel
        {
            Title = "Done",
            Status = "Done",
            Stories = done
        }
    };
}

<div class="row g-3">
    @foreach (var column in columns)
    {
        @await Html.PartialAsync("_Column", column)
    }
</div>